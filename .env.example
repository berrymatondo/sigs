# ------------------------------------------------------------------------------
# SIGS — Variables d'environnement
# ------------------------------------------------------------------------------
# Copiez ce fichier en `.env` (ou `.env.local`) et renseignez les valeurs.
# En production sur Vercel, la plupart de ces variables sont injectées
# automatiquement par les intégrations connectées (Neon, Blob).
# Ne committez JAMAIS votre `.env` réel contenant des secrets.
# ------------------------------------------------------------------------------

# --- Base de données (Neon / Postgres) ----------------------------------------
# Chaîne de connexion principale utilisée par Prisma (lib/prisma.ts).
DATABASE_URL="postgres://user:password@host/dbname?sslmode=require"
# Connexion directe (sans pooling) — utile pour les migrations.
DATABASE_URL_UNPOOLED="postgres://user:password@host/dbname?sslmode=require"

# Variables Postgres fournies par l'intégration Neon (injectées en production).
POSTGRES_URL="postgres://user:password@host/dbname?sslmode=require"
POSTGRES_PRISMA_URL="postgres://user:password@host/dbname?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgres://user:password@host/dbname?sslmode=require"
POSTGRES_URL_NO_SSL="postgres://user:password@host/dbname"
POSTGRES_USER="user"
POSTGRES_PASSWORD="password"
POSTGRES_HOST="host"
POSTGRES_DATABASE="dbname"
PGUSER="user"
PGPASSWORD="password"
PGHOST="host"
PGHOST_UNPOOLED="host"
PGDATABASE="dbname"
NEON_PROJECT_ID="your-neon-project-id"

# --- Authentification (Better Auth) -------------------------------------------
# Secret de signature des sessions. Générez-en un avec : openssl rand -base64 32
BETTER_AUTH_SECRET="your-better-auth-secret"
# URL publique de l'application (utilisée pour les liens d'email et trustedOrigins).
# En local : http://localhost:3000 — en production, Vercel fournit VERCEL_URL.
BETTER_AUTH_URL="http://localhost:3000"

# --- Emails (Resend) -----------------------------------------------------------
# Clé API Resend pour l'envoi des emails (contact, accusé de réception, bienvenue).
# Si absente, l'envoi est ignoré (journalisé) sans bloquer l'application.
RESEND_API_KEY="re_your_resend_api_key"
# Expéditeur des emails (facultatif). Valeur par défaut : SIGS <onboarding@resend.dev>
RESEND_FROM_EMAIL="SIGS <onboarding@resend.dev>"

# --- Stockage de fichiers (Vercel Blob) ----------------------------------------
# Jeton de lecture/écriture pour Vercel Blob (upload de documents).
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_your_token"
